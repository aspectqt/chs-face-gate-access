# MongoDB
MONGODB_URI=mongodb://localhost:27017/face_gate_db
MONGODB_DB_NAME=face_gate_db

# PHILSMS (Token mode - preferred)
PHILSMS_BASE_URL=https://app.philsms.com/api/v3
PHILSMS_API_TOKEN=your_philsms_api_token_here
PHILSMS_SENDER_ID=PhilSMS
PHILSMS_SEND_PATH=/sms/send
PHILSMS_MESSAGE_TYPE=plain
PHILSMS_USER_AGENT=CHSGateAccess/1.0
PHILSMS_TIMEOUT_SECONDS=10
PHILSMS_MAX_RETRIES=3
PHILSMS_BACKOFF_SECONDS=0.6

# PHILSMS (OAuth mode - optional alternative)
# PHILSMS_CLIENT_ID=
# PHILSMS_CLIENT_SECRET=
# PHILSMS_TOKEN_URL=https://app.philsms.com/api/v3/oauth/token
# PHILSMS_REFRESH_TOKEN=

# OTP
OTP_CODE_LENGTH=6
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_THROTTLE_SECONDS=60
OTP_MAX_PER_HOUR=5
OTP_MESSAGE_TEMPLATE=Your CHS Gate Access OTP is {code}. It expires in {minutes} minutes.

# Gate scan cooldown (seconds, min 5)
SCAN_COOLDOWN_SECONDS=8

# Development server auto-reload (set to 1 while developing)
FLASK_DEBUG=1
SESSION_COOKIE_SECURE=0

# Security headers
ENABLE_SECURITY_HEADERS=1
# Set to 1 to enforce CSP; keep 0 in development to use Report-Only mode.
CSP_ENFORCE=0

# Debug route fallback recipient
TEST_SMS_RECIPIENT=+639171234567
